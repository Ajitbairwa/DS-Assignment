subjects = ("Python", "Java", "C", "C++", "DSA")

print("Tuple :- ", subjects)

print("First Element :- ", subjects[0])

print("Last Element :- ", subjects[-1])

print("Length of Tuple :- ", len(subjects))

print("Slicing :- ", subjects[1:4])


num = (10, 20, 30, 40, 50)

print("Numerical Tuple :- ", num)

print("Maximum Element :- ", max(num))

print("Minimum Element :- ", min(num))

print("Sum of Elements :- ", sum(num))